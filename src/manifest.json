{
  "manifest_version": 3,
  "name": "SeeWhatISee",
  "version": "1.0.0",
  "description": "Share a screenshot with your coding agent in a single click! (For Claude, Gemini, etc.)",
  "homepage_url": "https://github.com/jshute96/SeeWhatISee/blob/main/README.md",
  "permissions": ["activeTab", "clipboardWrite", "contextMenus", "downloads", "offscreen", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SeeWhatISee — Capture visible tab",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "description": "Activate SeeWhatISee (same as clicking the toolbar icon)"
    },
    "01-secondary-action": {
      "description": "Secondary action (same as double-click)"
    },
    "11-capture-screenshot": {
      "description": "Take screenshot"
    },
    "12-capture-page-contents": {
      "description": "Save HTML contents"
    },
    "13-capture-with-details": {
      "description": "Capture…"
    },
    "14-capture-url": {
      "description": "Capture URL"
    },
    "15-capture-both": {
      "description": "Capture screenshot and HTML"
    },
    "21-capture-selection-html": {
      "description": "Capture selection as HTML"
    },
    "22-capture-selection-text": {
      "description": "Capture selection as text"
    },
    "23-capture-selection-markdown": {
      "description": "Capture selection as markdown"
    }
  }
}
