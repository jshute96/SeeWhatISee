{
  "name": "seewhatisee",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for taking screenshots and handing them to coding agents.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "pretest": "node scripts/build.mjs",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "clean": "rm -rf dist test-results playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
