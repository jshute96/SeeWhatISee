{
  "name": "seewhatisee",
  "version": "1.0.3",
  "private": true,
  "description": "The ultimate Chrome extension screenshot tool for vibe-coding: Share screenshots, HTML, or selected text with your coding agent — CLI or web.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "mcp-server"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:mcp-server": "npm run build --workspace=@seewhatisee/mcp-server --silent",
    "watch": "node scripts/build.mjs --watch",
    "test": "npm run test:skills && npm run test:unit && npm run test:mcp-server && npm run test:e2e",
    "test:skills": "python3 skills/generate-skills.py",
    "pretest:e2e": "node scripts/build.mjs",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "pretest:unit": "node scripts/build.mjs",
    "test:unit": "node --test 'tests/unit/*.test.mjs'",
    "test:mcp-server": "npm test --workspace=@seewhatisee/mcp-server --silent",
    "pretest:live": "node scripts/build.mjs",
    "test:live": "playwright test --config=playwright.config.live.ts",
    "pretest:live-claude": "node scripts/build.mjs",
    "test:live-claude": "playwright test --config=playwright.config.live.ts --project=claude",
    "pretest:live-claude-code": "node scripts/build.mjs",
    "test:live-claude-code": "playwright test --config=playwright.config.live.ts --project=claude-code",
    "pretest:live-gemini": "node scripts/build.mjs",
    "test:live-gemini": "playwright test --config=playwright.config.live.ts --project=gemini",
    "pretest:live-chatgpt": "node scripts/build.mjs",
    "test:live-chatgpt": "playwright test --config=playwright.config.live.ts --project=chatgpt",
    "pretest:live-google": "node scripts/build.mjs",
    "test:live-google": "playwright test --config=playwright.config.live.ts --project=google",
    "open-test-browser": "scripts/open-test-browser.sh",
    "clean": "rm -rf dist test-results playwright-report"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@playwright/test": "^1.49.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "@types/pngjs": "^6.0.5",
    "codejar": "^4.3.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0"
  }
}
