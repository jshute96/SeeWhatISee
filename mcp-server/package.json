{
  "name": "@seewhatisee/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for collecting screenshots and captured data from the SeeWhatISee Chrome extension",
  "type": "module",
  "bin": {
    "seewhatisee-mcp": "dist/seewhatisee-mcp.js"
  },
  "scripts": {
    "prompts": "node build-prompts.mjs",
    "postinstall": "node build-prompts.mjs && tsc",
    "build": "npm run prompts && tsc && node bundle.mjs",
    "pretest": "npm run prompts && tsc",
    "test": "node --test 'tests/*.test.mjs'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
